{
  "name": "dep-incubation-dashboard",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@dep-incubation-dashboard/web",
    "dev:api": "turbo run dev --filter=@dep-incubation-dashboard/api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @dep-incubation-dashboard/web exec eslint --fix"
    ],
    "apps/api/**/*.ts": [
      "pnpm --filter @dep-incubation-dashboard/api exec eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@scarf/scarf",
      "prisma"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
